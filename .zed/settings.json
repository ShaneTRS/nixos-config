{
  "hard_tabs": false,
  "languages": {
    "Nix": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "alejandra"
        }
      }
    }
  },
  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "(builtins.getFlake \"${builtins.getEnv \"PWD\"}\").legacyPackages.x86_64-linux"
        },
        "options": {
          "nixos": {
            "expr": "(builtins.getFlake \"${builtins.getEnv \"PWD\"}\").nixosConfigurations.\"${builtins.getEnv \"TUNDRA_ID\" or \"persephone\"}\".options"
          }
        }
      }
    }
  }
}